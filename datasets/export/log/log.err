def parse_document(file_path):
    """
    This function parses a text file and returns a list of elements.
    
    Args:
        file_path (str): The path to the text file.
    
    Returns:
        list: A list of elements in the document.
    """

    # Open the file in read mode
    with open(file_path, 'r') as file:
        
        # Read the content of the file
        content = file.read()
        
        # Split the content into lines
        lines = content.split('\n')
        
        # Initialize an empty list to store the elements
        elements = []
        
        # Iterate over each line in the content
        for line in lines:
            # Check if the line contains a table
            if '<table>' in line:
                # If the line contains a table, extract the table and add it to the elements list
                table = line.split('<table>')[1].split('</table>')[0]
                elements.append(table)
            # Check if the line contains an image
            elif '<img>' in line:
                # If the line contains an image, extract the image and add it to the elements list
                image = line.split('<img>')[1].split('</img>')[0]
                elements.append(image)
            else:
                # If the line does not contain a table or an image, add it to the elements list as is
                elements.append(line)
        
        # Return the list of elements
        return elements

# Test the function
